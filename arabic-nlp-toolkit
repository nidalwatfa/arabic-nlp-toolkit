import re
import unicodedata

class ArabicNormalizer:
    """
    تطبيع النصوص العربية
    """
    
    def __init__(self):
        # أحرف الهمزة المختلفة
        self.alef_variants = ['أ', 'إ', 'آ', 'ٱ']
        self.alef_normalized = 'ا'
        
        # التشكيل
        self.arabic_diacritics = re.compile(r'[\u0617-\u061A\u064B-\u0652]')
        
        # علامات الترقيم العربية
        self.arabic_punctuations = '۔،؛؟'
        
    def remove_diacritics(self, text):
        """إزالة التشكيل من النص"""
        return self.arabic_diacritics.sub('', text)
    
    def normalize_alef(self, text):
        """توحيد أشكال الألف"""
        for variant in self.alef_variants:
            text = text.replace(variant, self.alef_normalized)
        return text
    
    def normalize_teh_marbuta(self, text):
        """تحويل التاء المربوطة إلى هاء"""
        return text.replace('ة', 'ه')
    
    def remove_tatweel(self, text):
        """إزالة التطويل"""
        return text.replace('ـ', '')
    
    def remove_non_arabic(self, text):
        """إزالة الأحرف غير العربية"""
        return re.sub(r'[^\u0600-\u06FF\s]', '', text)
    
    def normalize_spacing(self, text):
        """توحيد المسافات"""
        return re.sub(r'\s+', ' ', text).strip()
    
    def normalize(self, text, remove_diacritics=True, normalize_alef=True,
                  normalize_teh=False, remove_tatweel=True,
                  remove_non_arabic=False, normalize_spacing=True):
        """
        تطبيع النص بشكل كامل
        
        Args:
            text: النص المراد تطبيعه
            remove_diacritics: إزالة التشكيل
            normalize_alef: توحيد الألف
            normalize_teh: تحويل التاء المربوطة
            remove_tatweel: إزالة التطويل
            remove_non_arabic: إزالة الأحرف غير العربية
            normalize_spacing: توحيد المسافات
        
        Returns:
            النص المطبّع
        """
        if remove_diacritics:
            text = self.remove_diacritics(text)
        
        if normalize_alef:
            text = self.normalize_alef(text)
        
        if normalize_teh:
            text = self.normalize_teh_marbuta(text)
        
        if remove_tatweel:
            text = self.remove_tatweel(text)
        
        if remove_non_arabic:
            text = self.remove_non_arabic(text)
        
        if normalize_spacing:
            text = self.normalize_spacing(text)
        
        return text

