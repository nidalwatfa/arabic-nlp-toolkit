import re

class ArabicTokenizer:
    """
    تقطيع النصوص العربية إلى كلمات وجمل
    """
    
    def __init__(self):
        # نمط الجمل العربية
        self.sentence_pattern = re.compile(r'[.!?؟۔]+')
        
        # نمط الكلمات
        self.word_pattern = re.compile(r'[\u0600-\u06FF]+')
    
    def tokenize_sentences(self, text):
        """
        تقطيع النص إلى جمل
        
        Args:
            text: النص المراد تقطيعه
        
        Returns:
            قائمة الجمل
        """
        sentences = self.sentence_pattern.split(text)
        return [s.strip() for s in sentences if s.strip()]
    
    def tokenize_words(self, text):
        """
        تقطيع النص إلى كلمات
        
        Args:
            text: النص المراد تقطيعه
        
        Returns:
            قائمة الكلمات
        """
        words = self.word_pattern.findall(text)
        return words
    
    def tokenize(self, text, level='word'):
        """
        تقطيع النص
        
        Args:
            text: النص المراد تقطيعه
            level: مستوى التقطيع ('word' أو 'sentence')
        
        Returns:
            قائمة الوحدات (كلمات أو جمل)
        """
        if level == 'sentence':
            return self.tokenize_sentences(text)
        else:
            return self.tokenize_words(text)

