import re


class ArabicTokenizer:
    """
    تقطيع النصوص العربية إلى كلمات وجمل
    """

    def __init__(self):
        # نمط نهاية الجملة (نقاط، علامات استفهام، علامات نهاية جمل عربية)
        self.sentence_pattern = re.compile(r"[.!?؟۔]+")
        # نمط الكلمات: أحرف عربية تسلسلية (يشمل الحروف الأساسية)
        self.word_pattern = re.compile(r"[\u0600-\u06FF]+")

    def tokenize_sentences(self, text: str):
        """
        تقطيع النص إلى جمل
        Returns: قائمة الجمل (بعد تنظيف المسافات الفارغة)
        """
        if not text:
            return []
        sentences = self.sentence_pattern.split(text)
        return [s.strip() for s in sentences if s.strip()]

    def tokenize_words(self, text: str):
        """
        تقطيع النص إلى كلمات
        Returns: قائمة الكلمات
        """
        if not text:
            return []
        words = self.word_pattern.findall(text)
        return words

    def tokenize(self, text: str, level: str = "word"):
        """
        تقطيع النص حسب المستوى المطلوب ('word' أو 'sentence')
        """
        if level == "sentence":
            return self.tokenize_sentences(text)
        return self.tokenize_words(text)

