from setuptools import setup, find_packages

with open("README.md", "r", encoding="utf-8") as fh:
    long_description = fh.read()

setup(
    name="arabic-nlp-toolkit",
    version="0.1.0",
    author="Nidal Watfa",
    author_email="nidalwatfa99@gmail.com",
    description="مكتبة معالجة اللغة الطبيعية للغة العربية",
    long_description=long_description,
    long_description_content_type="text/markdown",
    url="https://github.com/nidalwatfa/arabic-nlp-toolkit",
    packages=find_packages(),
    classifiers=[
        "Programming Language :: Python :: 3",
        "License :: OSI Approved :: MIT License",
        "Operating System :: OS Independent",
        "Natural Language :: Arabic",
        "Topic :: Text Processing :: Linguistic",
    ],
    python_requires=">=3.7",
    include_package_data=True,
    package_data={
        'arabic_nlp_toolkit': ['data/*.txt'],
    },
    keywords='arabic nlp natural-language-processing tokenization stemming normalization',
)

