"""
مثال على استخدام Arabic NLP Toolkit
"""

from arabic_nlp_toolkit import (
    ArabicNormalizer,
    ArabicTokenizer,
    ArabicStemmer,
    StopwordsRemover,
    ArabicTextAnalyzer,
)

def main():
    print("=" * 60)
    print("مثال على استخدام Arabic NLP Toolkit")
    print("=" * 60)
    print()

    # النص التجريبي
    text = """
    مَرْحَباً بِكُمْ في مكتبة معالجة اللغة العربية. 
    هذه المكتبة توفر أدوات متقدمة لمعالجة النصوص العربية.
    يمكنك استخدامها في مشاريعك بسهولة.
    """

    print("النص الأصلي:")
    print(text)
    print("\n" + "=" * 60 + "\n")

    # 1. التطبيع
    print("1. التطبيع (Normalization)")
    print("-" * 60)
    normalizer = ArabicNormalizer()
    normalized_text = normalizer.normalize(text)
    print("النص بعد التطبيع:")
    print(normalized_text)
    print()

    # 2. التقطيع
    print("2. التقطيع (Tokenization)")
    print("-" * 60)
    tokenizer = ArabicTokenizer()

    sentences = tokenizer.tokenize_sentences(normalized_text)
    print(f"عدد الجمل: {len(sentences)}")
    for i, sentence in enumerate(sentences, 1):
        print(f"  الجملة {i}: {sentence}")
    print()

    words = tokenizer.tokenize_words(normalized_text)
    print(f"عدد الكلمات: {len(words)}")
    print(f"الكلمات: {', '.join(words[:10])}...")
    print()

    # 3. إزالة الكلمات الشائعة
    print("3. إزالة الكلمات الشائعة (Stop Words Removal)")
    print("-" * 60)
    stopwords_remover = StopwordsRemover()
    filtered_words = stopwords_remover.remove(words)
    print(f"عدد الكلمات بعد إزالة الكلمات الشائعة: {len(filtered_words)}")
    print(f"الكلمات: {', '.join(filtered_words)}")
    print()

    # 4. استخراج الجذور
    print("4. استخراج الجذور (Stemming)")
    print("-" * 60)
    stemmer = ArabicStemmer()
    test_words = ["المدرسة", "ومدرسة", "المعلمين", "كتاب"]
    stemmed = [stemmer.stem(w) for w in test_words]
    for w, s in zip(test_words, stemmed):
        print(f"{w} -> {s}")
    print()

    # 5. استخدام المحلل الشامل
    print("5. تحليل نص شامل (Analyzer)")
    print("-" * 60)
    analyzer = ArabicTextAnalyzer()
    report = analyzer.analyze(text, normalize=True, remove_stopwords=True, stem=True)
    print("إحصائيات:")
    for k, v in report["statistics"].items():
        print(f"  {k}: {v}")
    print("\nأكثر الكلمات شيوعاً:")
    print(report["most_common_words"])

if __name__ == "__main__":
    main()
