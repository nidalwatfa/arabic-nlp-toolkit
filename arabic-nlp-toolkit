import re


class ArabicStemmer:
    """
    استخراج جذور الكلمات العربية (أداة بسيطة تعتمد على إزالة سوابق ولواحق شائعة).
    هذه ليست خوارزمية جذر كاملة لكنها مفيدة كخط أساس.
    """

    def __init__(self):
        # سوابق شائعة (مرتبة تقريبيًا)
        self.prefixes = [
            "ال",
            "وال",
            "فال",
            "بال",
            "كال",
            "ولل",
            "لل",
            "و",
            "ف",
            "ب",
            "ك",
            "ل",
        ]

        # لواحق شائعة
        self.suffixes = [
            "كما",
            "هما",
            "هم",
            "هن",
            "ها",
            "ان",
            "ات",
            "ون",
            "ين",
            "ه",
            "ة",
            "ي",
            "ك",
            "ت",
            "كم",
            "كن",
            "نا",
            "ني",
            "وا",
            "ما",
            "وه",
            "يه",
            "ئ",
        ]

        # أحرف ضعيفة (قد تستخدم لاحقاً)
        self.weak_letters = ["ا", "و", "ي"]

    def remove_prefixes(self, word: str) -> str:
        """إزالة السوابق إذا كان طول الكلمة بعد الإزالة معقولاً"""
        if not word:
            return word
        for prefix in sorted(self.prefixes, key=len, reverse=True):
            if word.startswith(prefix) and len(word) > len(prefix) + 2:
                return word[len(prefix) :]
        return word

    def remove_suffixes(self, word: str) -> str:
        """إزالة اللواحق إذا كان طول الكلمة بعد الإزالة معقولاً"""
        if not word:
            return word
        for suffix in sorted(self.suffixes, key=len, reverse=True):
            if word.endswith(suffix) and len(word) > len(suffix) + 2:
                return word[: -len(suffix)]
        return word

    def stem(self, word: str) -> str:
        """
        استخراج جذر كلمة مفردة
        """
        if not word or len(word) < 3:
            return word

        w = self.remove_prefixes(word)
        w = self.remove_suffixes(w)
        return w

    def stem_text(self, text: str) -> str:
        """استخراج جذور كل كلمات النص (تفصل حسب المسافات)"""
        if not text:
            return ""
        words = text.split()
        stemmed_words = [self.stem(word) for word in words]
        return " ".join(stemmed_words)

