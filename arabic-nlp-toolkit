class TestArabicStemmer(unittest.TestCase):
    
    def setUp(self):
        self.stemmer = ArabicStemmer()
    
    def test_remove_prefixes(self):
        word = "والمدرسة"
        result = self.stemmer.remove_prefixes(word)
        self.assertNotIn('وال', result)
    
    def test_remove_suffixes(self):
        word = "المعلمون"
        result = self.stemmer.remove_suffixes(word)
        self.assertNotIn('ون', result)
    
    def test_stem_word(self):
        word = "والمعلمون"
        result = self.stemmer.stem(word)
        self.assertIsInstance(result, str)
        self.assertLess(len(result), len(word))
    
    def test_stem_short_word(self):
        word = "من"
        result = self.stemmer.stem(word)
        self.assertEqual(result, word)

if __name__ == '__main__':
    unittest.main()

