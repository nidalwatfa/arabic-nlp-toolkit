import os


class StopwordsRemover:
    """
    إزالة الكلمات الشائعة (Stop Words)
    """

    def __init__(self, custom_stopwords=None):
        # قائمة الكلمات الشائعة الافتراضية
        self.default_stopwords = {
            "في",
            "من",
            "إلى",
            "الى",
            "على",
            "عن",
            "هذا",
            "هذه",
            "ذلك",
            "ذاك",
            "التي",
            "الذي",
            "التى",
            "هو",
            "هي",
            "أن",
            "إن",
            "كان",
            "كانت",
            "لم",
            "لن",
            "قد",
            "كل",
            "بعض",
            "أي",
            "أو",
            "لكن",
            "مع",
            "عند",
            "منذ",
            "حتى",
            "و",
            "ف",
            "ب",
            "ك",
            "ل",
            "ما",
            "لا",
            "إلا",
            "غير",
            "بل",
            "أم",
            "أما",
            "هل",
            "نعم",
            "لماذا",
            "كيف",
            "أين",
            "متى",
            "تلك",
            "هؤلاء",
            "أولئك",
            "أنا",
            "نحن",
            "أنت",
            "أنتم",
            "أنتن",
            "هما",
            "هم",
            "هن",
        }

        # ابدأ بالقائمة الافتراضية ثم أضف المخصص إن وُجد
        self.stopwords = set(self.default_stopwords)
        if custom_stopwords:
            # دعم قائمة أو سلسلة مفصولة
            if isinstance(custom_stopwords, str):
                self.stopwords.add(custom_stopwords)
            else:
                self.stopwords.update(custom_stopwords)

        # تحميل كلمات من ملف data/stopwords.txt إن وُجد
        self._load_stopwords_from_file()

    def _load_stopwords_from_file(self):
        """تحميل الكلمات الشائعة من ملف data/stopwords.txt إن وُجد"""
        try:
            data_dir = os.path.join(os.path.dirname(__file__), "data")
            stopwords_file = os.path.join(data_dir, "stopwords.txt")

            if os.path.exists(stopwords_file):
                with open(stopwords_file, "r", encoding="utf-8") as f:
                    file_stopwords = {line.strip() for line in f if line.strip() and not line.strip().startswith("#")}
                    self.stopwords.update(file_stopwords)
        except Exception:
            # عدم إفشال البرنامج في حال فشل التحميل؛ يمكن تسجيل الخطأ لاحقاً
            pass

    def remove(self, words):
        """
        إزالة الكلمات الشائعة من قائمة كلمات
        Args:
            words: قائمة الكلمات (قائمة أو تكرار)
        Returns:
            قائمة الكلمات بعد إزالة الكلمات الشائعة
        """
        if not words:
            return []
        return [word for word in words if word not in self.stopwords]

    def remove_from_text(self, text: str) -> str:
        """
        إزالة الكلمات الشائعة من نص
        Args:
            text: النص المراد معالجته
        Returns:
            النص بعد إزالة الكلمات الشائعة
        """
        if not text:
            return ""
        words = text.split()
        filtered_words = self.remove(words)
        return " ".join(filtered_words)

    def add_stopwords(self, words):
        """إضافة كلمات جديدة إلى قائمة الكلمات الشائعة"""
        if not words:
            return
        if isinstance(words, str):
            self.stopwords.add(words)
        else:
            self.stopwords.update(words)

    def remove_stopwords_from_list(self, words):
        """إزالة كلمات من قائمة الكلمات الشائعة"""
        if not words:
            return
        if isinstance(words, str):
            self.stopwords.discard(words)
        else:
            self.stopwords.difference_update(words)

