import re


class StopwordsRemover:
    """
    فئة لإزالة كلمات الوقف من النصوص العربية
    """
    
    def __init__(self, custom_stopwords=None):
        """
        custom_stopwords: قائمة اختيارية بكلمات وقف إضافية
        """
        self.stopwords = self._load_stopwords()
        
        if custom_stopwords:
            self.stopwords.update(custom_stopwords)
    
    def _load_stopwords(self):
        """
        تحميل كلمات الوقف من الملف
        """
        stopwords_path = os.path.join(
            os.path.dirname(__file__), 
            'data', 
            'stopwords.txt'
        )
        
        stopwords = set()
        try:
            with open(stopwords_path, 'r', encoding='utf-8') as f:
                stopwords = set(line.strip() for line in f if line.strip())
        except FileNotFoundError:
            print(f"تحذير: ملف كلمات الوقف غير موجود في {stopwords_path}")
        
        return stopwords
    
    def remove_stopwords(self, text):
        """
        إزالة كلمات الوقف من النص
        """
        if not text:
            return ""
        
        words = text.split()
        filtered_words = [word for word in words if word not in self.stopwords]
        
        return ' '.join(filtered_words)
    
    def add_stopword(self, word):
        """
        إضافة كلمة وقف جديدة
        """
        self.stopwords.add(word)
    
    def remove_stopword(self, word):
        """
        إزالة كلمة من قائمة كلمات الوقف
        """
        self.stopwords.discard(word)
    
    def get_stopwords(self):
        """
        الحصول على قائمة كلمات الوقف
        """
        return self.stopwords
tokenizer.pyimport re


class ArabicTokenizer:
    """
    فئة لتجزئة النصوص العربية إلى كلمات
    """
    
    def __init__(self):
        self.punctuation_pattern = r'[،؛؟!.\'"():;?!\-\[\]{}\\/]'
    
    def tokenize(self, text):
        """
        تجزئة النص إلى كلمات
        """
        if not text:
            return []
        
        # إزالة علامات الترقيم
        text = re.sub(self.punctuation_pattern, ' ', text)
        
        # تقسيم النص إلى كلمات
        tokens = text.split()
        
        # إزالة المسافات الفارغة
        tokens = [token.strip() for token in tokens if token.strip()]
        
        return tokens
    
    def tokenize_sentences(self, text):
        """
        تجزئة النص إلى جمل
        """
        if not text:
            return []
        
        # تقسيم النص بناءً على علامات الترقيم المنهية للجمل
        sentences = re.split(r'[.!?؟!。]', text)
        
        # إزالة الجمل الفارغة
        sentences = [sent.strip() for sent in sentences if sent.strip()]
        
        return sentences
    
    def word_tokenize(self, text, keep_punctuation=False):
        """
        تجزئة متقدمة للكلمات مع خيار الحفاظ على علامات الترقيم
        """
        if not text:
            return []
        
        if keep_punctuation:
            # تقسيم مع الحفاظ على علامات الترقيم
            tokens = re.findall(r'\w+|[^\w\s]', text, re.UNICODE)
        else:
            tokens = self.tokenize(text)
        
        return tokens
    
    def char_tokenize(self, text):
        """
        تجزئة النص إلى أحرف
        """
        if not text:
            return []
        
        return list(text.replace(' ', ''))
stemmer.pyimport re


class ArabicStemmer:
    """
    فئة للتجذير البسيط للكلمات العربية
    """
    
    def __init__(self):
        # البادئات الشائعة
        self.prefixes = ['ال', 'و', 'ف', 'ب', 'ك', 'ل', 'لل']
        
        # اللواحق الشائعة
        self.suffixes = ['ها', 'ان', 'ات', 'ون', 'ين', 'يه', 'ه', 'ة', 'ي', 'ك', 'ت', 'كم', 'كن', 'نا', 'ني', 'وا', 'ما', 'هم', 'هن', 'كما', 'هما', 'نا', 'ني']
        
    def stem(self, word):
        """
        استخراج جذر الكلمة
        """
        if not word or len(word) < 3:
            return word
        
        stemmed_word = word
        
        # إزالة البادئات
        stemmed_word = self._remove_prefix(stemmed_word)
        
        # إزالة اللواحق
        stemmed_word = self._remove_suffix(stemmed_word)
        
        # التأكد من أن الكلمة لا تقل عن 3 أحرف
        if len(stemmed_word) < 3:
            return word
        
        return stemmed_word
    
    def _remove_prefix(self, word):
        """
        إزالة البادئات
        """
        for prefix in sorted(self.prefixes, key=len, reverse=True):
            if word.startswith(prefix) and len(word) > len(prefix) + 2:
                return word[len(prefix):]
        return word
    
    def _remove_suffix(self, word):
        """
        إزالة اللواحق
        """
        for suffix in sorted(self.suffixes, key=len, reverse=True):
            if word.endswith(suffix) and len(word) > len(suffix) + 2:
                return word[:-len(suffix)]
        return word
    
    def stem_sentence(self, sentence):
        """
        تجذير جملة كاملة
        """
        if not sentence:
            return ""
        
        words = sentence.split()
        stemmed_words = [self.stem(word) for word in words]
        
        return ' '.join(stemmed_words)
    
    def stem_list(self, words):
        """
        تجذير قائمة من الكلمات
        """
        if not words:
            return []
        
        return [self.stem(word) for word in words]
