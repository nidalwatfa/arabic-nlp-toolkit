import re

class ArabicTextAnalyzer:
    """
    محلل نصوص عربي شامل
    """
    
    def __init__(self):
        self.normalizer = ArabicNormalizer()
        self.tokenizer = ArabicTokenizer()
        self.stemmer = ArabicStemmer()
        self.stopwords_remover = StopwordsRemover()
    
    def analyze(self, text, normalize=True, remove_stopwords=False, stem=False):
        """
        تحليل النص بشكل شامل
        
        Args:
            text: النص المراد تحليله
            normalize: تطبيع النص
            remove_stopwords: إزالة الكلمات الشائعة
            stem: استخراج الجذور
        
        Returns:
            قاموس يحتوي على التحليل
        """
        original_text = text
        
        # التطبيع
        if normalize:
            text = self.normalizer.normalize(text)
        
        # التقطيع
        sentences = self.tokenizer.tokenize_sentences(text)
        words = self.tokenizer.tokenize_words(text)
        
        # إزالة الكلمات الشائعة
        if remove_stopwords:
            words = self.stopwords_remover.remove(words)
        
        # استخراج الجذور
        if stem:
            words = [self.stemmer.stem(word) for word in words]
        
        # الإحصائيات
        char_count = len(text)
        word_count = len(words)
        sentence_count = len(sentences)
        unique_words = len(set(words))
        
        # الكلمات الأكثر تكراراً
        word_freq = {}
        for word in words:
            word_freq[word] = word_freq.get(word, 0) + 1
        
        most_common = sorted(word_freq.items(), key=lambda x: x[1], reverse=True)[:10]
        
        return {
            'original_text': original_text,
            'processed_text': text,
            'sentences': sentences,
            'words': words,
            'statistics': {
                'char_count': char_count,
                'word_count': word_count,
                'sentence_count': sentence_count,
                'unique_words': unique_words,
                'avg_word_length': sum(len(w) for w in words) / word_count if word_count > 0 else 0,
                'avg_sentence_length': word_count / sentence_count if sentence_count > 0 else 0
            },
            'word_frequency': word_freq,
            'most_common_words': most_common
        }
    
    def get_word_frequency(self, text):
        """الحصول على تكرار الكلمات"""
        words = self.tokenizer.tokenize_words(text)
        word_freq = {}
        for word in words:
            word_freq[word] = word_freq.get(word, 0) + 1
        return word_freq
    
    def get_statistics(self, text):
        """الحصول على إحصائيات النص"""
        sentences = self.tokenizer.tokenize_sentences(text)
        words = self.tokenizer.tokenize_words(text)
        
        return {
            'char_count': len(text),
            'word_count': len(words),
            'sentence_count': len(sentences),
            'unique_words': len(set(words)),
            'avg_word_length': sum(len(w) for w in words) / len(words) if words else 0,
            'avg_sentence_length': len(words) / len(sentences) if sentences else 0
        }

