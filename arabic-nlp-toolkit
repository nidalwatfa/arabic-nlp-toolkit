import re
import unicodedata


class ArabicNormalizer:
    """
    تطبيع النصوص العربية
    """

    def __init__(self):
        # أشكال الألف المختلفة التي نريد توحيدها
        self.alef_variants = ["أ", "إ", "آ", "ٱ"]
        self.alef_normalized = "ا"

        # التشكيل (الحركات) - تغطي معظم علامات التشكيل الشائعة
        self.arabic_diacritics = re.compile(r"[\u0617-\u061A\u064B-\u0652\u0670]")

        # التطويل
        self.tatweel = "ـ"

    def remove_diacritics(self, text: str) -> str:
        """إزالة التشكيل من النص"""
        if not text:
            return text
        return self.arabic_diacritics.sub("", text)

    def normalize_alef(self, text: str) -> str:
        """توحيد أشكال الألف"""
        if not text:
            return text
        for variant in self.alef_variants:
            text = text.replace(variant, self.alef_normalized)
        return text

    def normalize_teh_marbuta(self, text: str) -> str:
        """تحويل التاء المربوطة إلى هاء (اختياري)"""
        if not text:
            return text
        return text.replace("ة", "ه")

    def remove_tatweel(self, text: str) -> str:
        """إزالة التطويل (ـ)"""
        if not text:
            return text
        return text.replace(self.tatweel, "")

    def remove_non_arabic(self, text: str) -> str:
        """
        إزالة الأحرف غير العربية مع الإبقاء على المسافات.
        يدعم نطاقات الحروف العربية الأساسية والامتدادات الشائعة.
        """
        if not text:
            return text
        return re.sub(r"[^\u0600-\u06FF\u0750-\u077F\s]", "", text)

    def normalize_spacing(self, text: str) -> str:
        """توحيد المسافات"""
        if not text:
            return text
        return re.sub(r"\s+", " ", text).strip()

    def normalize(
        self,
        text: str,
        remove_diacritics: bool = True,
        normalize_alef: bool = True,
        normalize_teh: bool = False,
        remove_tatweel: bool = True,
        remove_non_arabic: bool = False,
        normalize_spacing: bool = True,
    ) -> str:
        """
        تطبيع النص بشكل كامل

        Args:
            text: النص المراد تطبيعه
            remove_diacritics: إزالة التشكيل
            normalize_alef: توحيد الألف
            normalize_teh: تحويل التاء المربوطة (اختياري)
            remove_tatweel: إزالة التطويل
            remove_non_arabic: إزالة الأحرف غير العربية
            normalize_spacing: توحيد المسافات

        Returns:
            النص المطبّع
        """
        if text is None:
            return ""

        if remove_diacritics:
            text = self.remove_diacritics(text)

        if normalize_alef:
            text = self.normalize_alef(text)

        if normalize_teh:
            text = self.normalize_teh_marbuta(text)

        if remove_tatweel:
            text = self.remove_tatweel(text)

        if remove_non_arabic:
            text = self.remove_non_arabic(text)

        if normalize_spacing:
            text = self.normalize_spacing(text)

        return text

