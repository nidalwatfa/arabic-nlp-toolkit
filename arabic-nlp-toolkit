import unittest
import sys
import os

# إضافة المسار للمكتبة
sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '..')))

from arabic_nlp_toolkit import ArabicNormalizer

class TestArabicNormalizer(unittest.TestCase):
    
    def setUp(self):
        self.normalizer = ArabicNormalizer()
    
    def test_remove_diacritics(self):
        text = "مَرْحَباً بِكُمْ"
        expected = "مرحبا بكم"
        result = self.normalizer.remove_diacritics(text)
        self.assertEqual(result, expected)
    
    def test_normalize_alef(self):
        text = "أحمد إبراهيم آمن"
        expected = "احمد ابراهيم امن"
        result = self.normalizer.normalize_alef(text)
        self.assertEqual(result, expected)
    
    def test_normalize_teh_marbuta(self):
        text = "مدرسة جميلة"
        expected = "مدرسه جميله"
        result = self.normalizer.normalize_teh_marbuta(text)
        self.assertEqual(result, expected)
    
    def test_remove_tatweel(self):
        text = "الســـــلام عليكـــــم"
        expected = "السلام عليكم"
        result = self.normalizer.remove_tatweel(text)
        self.assertEqual(result, expected)
    
    def test_full_normalization(self):
        text = "مَرْحَباً بِكُمْ فِي المَكْتَبَةِ"
        result = self.normalizer.normalize(text)
        self.assertIsInstance(result, str)
        self.assertNotIn('َ', result)

if __name__ == '__main__':
    unittest.main()

