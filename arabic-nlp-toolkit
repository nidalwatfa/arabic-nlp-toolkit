## 📚 أمثلة متقدمة

### معالجة نص كامل
```python
from arabic_nlp_toolkit import (
    ArabicNormalizer,
    StopwordsRemover,
    ArabicTokenizer,
    ArabicTextAnalyzer
)

# النص الأصلي
text = """
البرمجة هي فن وعلم في نفس الوقت. 
تتطلب البرمجة الإبداع والمنطق والصبر.
المبرمجون يحلون المشاكل بطرق مبتكرة.
"""

# التطبيع
normalizer = ArabicNormalizer()
normalized = normalizer.normalize(text)

# إزالة كلمات الوقف
remover = StopwordsRemover()
cleaned = remover.remove_stopwords(normalized)

# التجزئة
tokenizer = ArabicTokenizer()
tokens = tokenizer.tokenize(cleaned)

# التحليل
analyzer = ArabicTextAnalyzer()
analysis = analyzer.analyze(text)
frequency = analyzer.word_frequency(cleaned)

print("الكلمات الأكثر تكراراً:", analyzer.get_top_words(cleaned, 5))
تحليل تكرار الكلمات
